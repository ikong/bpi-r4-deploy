{
    "luci-mod-network-wifimgr": {
        "description": "WiFi Manager BPI-R4 MT7988A",
        "read": {
            "file": {
                "/sys/kernel/debug/ieee80211/phy0/mt76/fw_version":         [ "read" ],
                "/sys/kernel/debug/ieee80211/phy0/mt76/sku_disable":        [ "read" ],
                "/sys/kernel/debug/ieee80211/phy0/mt76/band0/txpower_info": [ "read" ],
                "/sys/kernel/debug/ieee80211/phy0/mt76/band1/txpower_info": [ "read" ],
                "/sys/kernel/debug/ieee80211/phy0/mt76/band2/txpower_info": [ "read" ],
                "/sys/kernel/debug/ieee80211/phy0/dfs_status":              [ "read" ],
                "/proc/version":                                            [ "read" ],
                "/sbin/uci":                 [ "exec" ],
                "/bin/sh":                   [ "exec" ],
                "/bin/cat":                  [ "exec" ],
                "/bin/ubus":                 [ "exec" ],
                "/usr/sbin/iw":              [ "exec" ],
                "/usr/sbin/hostapd_cli":     [ "exec" ],
                "/usr/sbin/wpa_cli":         [ "exec" ],
                "/sbin/wifi":                [ "exec" ],
                "/sbin/iw":                  [ "exec" ],
                "/bin/logread":              [ "exec" ],
                "/sbin/logread":             [ "exec" ],
                "/usr/sbin/logread":         [ "exec" ]
            },
            "ubus": {
                "file":                [ "exec" ],
                "uci":                 [ "get" ],
                "network.wireless":    [ "status" ],
                "network.interface.*": [ "status" ],
                "hostapd.*":           [ "get_status", "get_clients" ],
                "iwinfo":              [ "info", "devices", "scan" ]
            },
            "uci": [ "wireless" ]
        },
        "write": {
            "file": {
                "/sbin/uci":    [ "exec" ],
                "/sbin/wifi":   [ "exec" ],
                "/sbin/reboot": [ "exec" ],
                "/bin/sh":      [ "exec" ]
            },
            "ubus": {
                "file": [ "exec" ],
                "uci":  [ "set", "commit", "add", "delete" ]
            },
            "uci": [ "wireless" ]
        }
    }
}
