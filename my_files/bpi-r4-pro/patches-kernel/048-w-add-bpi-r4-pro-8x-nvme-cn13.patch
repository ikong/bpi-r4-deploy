From: woziwrt build overlay
Subject: [PATCH] arm64: dts: mediatek: bpi-r4-pro-8x: enable second NVMe (CN13)

The Banana Pi BPI-R4 Pro 8X routes the "PCIe3.0 1L_P0 / USB3.2 P0" combo
lane to the upper M.2 key-M slot (CN13) through a mux selected by GPIO79.
In the stock DTS this lane is used as USB3 (ssusb0, PHY xphyu3port0), the
mux (GPIO79) is parked on the key-B branch (output-low) and the PCIe
controller for that lane (pcie2) is disabled, so only the CN14 NVMe
(pcie3) comes up.

This patch reassigns the shared combo PHY from USB3 to PCIe so that a
second NVMe SSD in CN13 is detected:

  1. ssusb0 (USB3 on xphyu3port0) is disabled to release the combo PHY.
     xphyu3port0 is shared between ssusb0 (USB3) and pcie2 (PCIe); they
     are mutually exclusive. All key-B slots on this board are unused,
     so no USB device is lost. The USB3 hub on ssusb1 (tphyu3port0) is
     independent and stays enabled.
  2. pcie2 is enabled with its pinctrl (pcie2_pins is defined in
     mt7988a.dtsi, already included by the board DTS).
  3. The GPIO79 mux is flipped from key-B (output-low) to key-M CN13
     (output-high).

Applies on top of 046-arm64-dts-add-bpi-r4-pro-8x.patch.

Signed-off-by: build overlay
---
--- a/arch/arm64/boot/dts/mediatek/mt7988a-bananapi-bpi-r4-pro-8x.dts
+++ b/arch/arm64/boot/dts/mediatek/mt7988a-bananapi-bpi-r4-pro-8x.dts
@@ -604,9 +604,12 @@
 	status = "okay";
 };
 
-/* M.2 key-B CN15 / key-M CN13 - CN15 USB via VIA Labs hub (ssusb1), CN13 empty */
+/* M.2 key-M CN13 NVMe SSD - uses combo lane PCIe3.0 1L_P0 (shared PHY with ssusb0, which is disabled above) */
 &pcie2 {
-	status = "disabled";
+	pinctrl-names = "default";
+	pinctrl-0 = <&pcie2_pins>;
+	max-link-width = <1>;
+	status = "okay";
 };
 
 /* M.2 key-M SSD */
@@ -625,11 +628,11 @@
 		output-high;
 	};
 
-	/* 1L0 0=key-b (CN15), 1=key-m (CN13) - route to CN15 for LTE */
+	/* 1L0 0=key-b (CN15), 1=key-m (CN13) - route to key-m CN13 for NVMe */
 	pcie-2-hog {
 		gpio-hog;
 		gpios = <79 GPIO_ACTIVE_HIGH>;
-		output-low;
+		output-high;
 	};
 
 	/* 1L1 0=key-b (CN18), 1=key-m (CN14) */
@@ -664,7 +667,11 @@
 };
 
 &ssusb0 {
-	status = "okay";
+	/* Combo PHY xphyu3port0 is reassigned from USB3 to PCIe (pcie2) for the
+	 * second M.2 key-M NVMe slot (CN13). All key-B slots are unused, so
+	 * disabling this USB3 controller is safe. The USB3 hub on ssusb1
+	 * (tphyu3port0) is unaffected. */
+	status = "disabled";
 };
 
 &ssusb1 {
